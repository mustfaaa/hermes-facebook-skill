# ─────────────────────────────────────────────
# Meta / Facebook Credentials
# Get these from https://developers.facebook.com
# ─────────────────────────────────────────────

FB_APP_ID=your_meta_app_id_here
FB_APP_SECRET=your_meta_app_secret_here
FB_PAGE_ID=your_facebook_page_id_here
FB_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token_here

# ─────────────────────────────────────────────
# Business Identity (optional — used in prompts)
# ─────────────────────────────────────────────

BUSINESS_NAME=Your Insurance Brokerage Name
BUSINESS_COUNTRY=Libya
BUSINESS_WEBSITE=https://yourbroker.ly
BUSINESS_PHONE=+218-XX-XXXXXXX

# ─────────────────────────────────────────────
# Agent Behavior (optional)
# ─────────────────────────────────────────────

# Number of posts to generate per day (1–3 recommended)
DAILY_POST_COUNT=2

# Auto-post immediately or stage for human review (true / false)
AUTO_PUBLISH_POSTS=true

# Auto-reply immediately or stage replies for approval (true / false)
AUTO_REPLY_COMMENTS=false

# Always auto-like new comments (true / false)
AUTO_LIKE_COMMENTS=true
